---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import NavCard from '../components/NavCard.astro';
import { siteConfig } from '../config';

const gridColsClasses: Record<number, string> = {
  1: "grid-cols-1",
  2: "grid-cols-1 sm:grid-cols-2",
  3: "grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 xl:grid-cols-3",
  4: "grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4",
  5: "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5",
  6: "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-6",
};
---

<Layout title={siteConfig.siteTitle}>
  <main class="w-full h-full p-4 md:p-8 lg:p-10 2xl:p-16 flex lg:items-start justify-center transition-all duration-500">
    <div class="w-full max-w-[1600px] flex flex-col lg:flex-row gap-8 lg:gap-10 xl:gap-14 2xl:gap-16 transition-all duration-500">
      
      <!-- Left Sidebar -->
      <aside class="w-full lg:w-[280px] xl:w-[320px] shrink-0 lg:sticky lg:top-12 h-auto lg:h-max transition-all duration-500">
        <Sidebar />
      </aside>

      <!-- Right Content Area -->
      <section class={`flex-1 space-y-12 xl:space-y-16 lg:py-0 transition-all duration-500 min-w-0 ${siteConfig.footerIsFixed ? 'pb-28' : 'pb-8 lg:pb-12'}`}>
        {siteConfig.categories.map((category) => {
          const maxCols = category.maxItemsPerRow || 4;
          const gridClass = gridColsClasses[maxCols] || gridColsClasses[4];
          return (
          <div class="transition-all duration-500">
            <h2 class="text-2xl font-bold mb-6 flex items-center gap-2 text-slate-800 dark:text-slate-100 transition-colors duration-500">
              <span class="w-8 h-1 bg-gradient-to-r from-blue-500 to-indigo-500 rounded-full inline-block"></span>
              {category.name}
            </h2>
            {category.is_remoteuri && category.remote_uri ? (
              <div class="relative w-full overflow-hidden remote-category min-h-[100px]" data-uri={category.remote_uri} data-gridclass={gridClass} data-name={category.name}>
                <div class={`grid ${gridClass} gap-6 xl:gap-8 transition-all duration-500 remote-grid`}>
                  {/* Skeleton loader and glass lock screen will be injected here by client JS */}
                </div>
              </div>
            ) : (
              <div class={`grid ${gridClass} gap-6 xl:gap-8 transition-all duration-500`}>
                {category.links && category.links.map((link) => (
                  <div class="transition-all duration-500 h-full">
                    <NavCard link={link} />
                  </div>
                ))}
              </div>
            )}
          </div>
          );
        })}
      </section>
      
    </div>
  </main>
</Layout>

<script>
  import { ToastManager, initNotices } from '../scripts/toast';
  import { renderSkeletons, renderLockOverlay, renderLinks } from '../scripts/remoteCategories';

  // Show config notices
  document.addEventListener('DOMContentLoaded', () => {
    initNotices();
  });

  // Main logic
  document.addEventListener('DOMContentLoaded', () => {
    const remoteCategories = document.querySelectorAll('.remote-category');
    
    remoteCategories.forEach(async (container) => {
      const uri = container.getAttribute('data-uri');
      const gridElement = container.querySelector('.remote-grid');
      if (!uri || !gridElement) return;

      try {
        const res = await fetch(uri);
        if (res.status === 429) {
          throw new Error("429");
        }
        const data = await res.json();
        
        // Provide skeletons
        const count = data.link_count || 4;
        renderSkeletons(gridElement, count);

        if (data.need_pwd && data.challenge) {
          renderLockOverlay(container, gridElement, data.challenge, uri);
        } else if (data.links && !data.need_pwd) {
          container.classList.remove('min-h-[100px]');
          renderLinks(gridElement, data.links);
          ToastManager.show({
            title: "获取成功",
            message: "已免密获取远程链接",
            type: "success",
            icon: "fa-solid fa-cloud-arrow-down",
            position: "top-right",
            duration: 3000
          });
        }
      } catch (e: any) {
        if (e.message === "429") {
          gridElement.innerHTML = '<div class="col-span-full p-4 text-center text-amber-500 bg-amber-100/10 rounded-lg">请求过于频繁，请稍后再试</div>';
          ToastManager.show({
            title: "被后端服务器拉黑",
            message: "您的请求过于频繁，已被远程服务器暂时拉黑，请稍后再试",
            type: "warning",
            icon: "fa-solid fa-hand",
            position: "top-right",
            duration: 5000
          });
        } else {
          gridElement.innerHTML = '<div class="col-span-full p-4 text-center text-red-500 bg-red-100/10 rounded-lg">获取远端分类失败</div>';
          ToastManager.show({
            title: "网络错误",
            message: "无法连接到远程服务器获取数据",
            type: "error",
            icon: "fa-solid fa-server",
            position: "top-right",
            duration: 5000
          });
        }
      }
    });
  });
</script>

<style>
  /* Hide scrollbar for Chrome, Safari and Opera */
  .scrollbar-hide::-webkit-scrollbar {
      display: none;
  }
  /* Hide scrollbar for IE, Edge and Firefox */
  .scrollbar-hide {
      -ms-overflow-style: none;  /* IE and Edge */
      scrollbar-width: none;  /* Firefox */
  }
</style>
