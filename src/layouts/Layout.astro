---
import '../styles/global.css';
import { siteConfig } from '../config';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href={siteConfig.faviconUrl || "/favicon.svg"} />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="text-slate-800 dark:text-slate-200 antialiased min-h-screen transition-colors duration-300 bg-slate-50 dark:bg-slate-950 overflow-x-hidden">
    
    <style is:global define:vars={{
      glassBlur: siteConfig.blurConfig.glassBlur,
      bgBlur: siteConfig.blurConfig.bgBlur,
      bgScale: siteConfig.blurConfig.bgScale
    }}>
      /* Use generic CSS variables mapped to Astro config for blur toggles */
      .glass, .glass-card {
        backdrop-filter: blur(var(--glassBlur));
        -webkit-backdrop-filter: blur(var(--glassBlur));
        /* Add specific transition for the filter to keep hover behaviors intact */
        transition: transform 0.3s ease, box-shadow 0.3s ease, backdrop-filter 0.7s ease-in-out, -webkit-backdrop-filter 0.7s ease-in-out;
      }
      #dynamic-background {
        filter: blur(var(--bgBlur));
        scale: var(--dynamic-scale, var(--bgScale));
        transition: filter 0.8s ease-in-out, scale 0.8s cubic-bezier(0.4, 0, 0.2, 1);
      }
      
      body.disable-blur #dynamic-background {
        filter: blur(0px) !important;
        scale: var(--dynamic-scale, 1) !important;
      }
    </style>

    <!-- Background Image -->
    {siteConfig.backgroundUrl && (
      <div 
        id="dynamic-background"
        class={`fixed -inset-10 z-[-1] bg-cover bg-center pointer-events-none transition-all duration-700 opacity-100 dark:opacity-40 ${siteConfig.blurConfig.bgDrift ? 'animate-bg-drift' : ''}`}
        style={`background-image: url('${siteConfig.backgroundUrl}');`}
      ></div>
    )}
    
    <div class="flex flex-col min-h-screen">
      <div class="flex-grow">
        <slot />
      </div>

      <!-- Default Footer -->
      {siteConfig.footer && (
        <div class={siteConfig.footerIsFixed ? "fixed bottom-0 left-0 w-full z-[100] pointer-events-auto" : "w-full z-[10] pointer-events-auto mt-auto flex-shrink-0"}>
          <div class="w-full py-4 glass border-x-0 border-b-0 rounded-none text-center text-sm font-bold leading-relaxed text-slate-700 dark:text-slate-300 [&_a]:text-blue-500 dark:[&_a]:text-blue-400 [&_a:hover]:underline [&_a:hover]:text-blue-600 dark:[&_a:hover]:text-blue-300 [&_a]:transition-colors">
            <Fragment set:html={siteConfig.footer} />
          </div>
        </div>
      )}
    </div>

    <script is:inline define:vars={{ defaultEnabled: siteConfig.blurConfig.defaultEnabled }}>
      // Initialize blur state
      const isBlurEnabled = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('enableBlur')) {
          return localStorage.getItem('enableBlur') === 'true';
        }
        return defaultEnabled;
      })();
      
      if (!isBlurEnabled) {
        document.body.classList.add('disable-blur');
      }
      
      // Apple Liquid Glass/Glossy lighting effect using JS
      const handleMouseMove = (e) => {
        const cards = document.querySelectorAll('.glass, .glass-card');
        for (const card of cards) {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          
          card.style.setProperty('--mouse-x', `${x}px`);
          card.style.setProperty('--mouse-y', `${y}px`);
        }
      };
      
      // Use requestAnimationFrame for smoother performance
      let isTicking = false;
      document.addEventListener('mousemove', (e) => {
        if (!isTicking) {
          window.requestAnimationFrame(() => {
            handleMouseMove(e);
            isTicking = false;
          });
          isTicking = true;
        }
      });
      
      // Global function to toggle blur
      window.toggleBlur = function() {
        const body = document.body;
        const isCurrentlyDisabled = body.classList.contains('disable-blur');
        
        if (isCurrentlyDisabled) {
          body.classList.remove('disable-blur');
          localStorage.setItem('enableBlur', 'true');
        } else {
          body.classList.add('disable-blur');
          localStorage.setItem('enableBlur', 'false');
        }
      };
    </script>
  </body>
</html>
